# Disable directory listing
Options -Indexes

# Custom 404 page
ErrorDocument 404 /404.html

# Enable URL rewriting
RewriteEngine On
RewriteBase /

# Auto-serve WebP images when browser supports it
RewriteCond %{HTTP_ACCEPT} image/webp
RewriteCond %{REQUEST_URI} (.+)\.(png|jpg|jpeg)$
RewriteCond %{DOCUMENT_ROOT}%1.webp -f
RewriteRule (.+)\.(png|jpg|jpeg)$ $1.webp [T=image/webp,L]

<IfModule mod_headers.c>
  <FilesMatch "\.(png|jpg|jpeg)$">
    Header append Vary Accept
  </FilesMatch>
</IfModule>

# Set default homepage
DirectoryIndex home.html index.html index.php

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Remove trailing slash from URLs (optional but recommended)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# Serve dynamic sitemap and articles page via PHP
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^articles\.html$ articles.php [L]

# Rewrite clean article URLs to article.php with slug parameter
# Example: /article/my-article-slug -> /article.php?slug=my-article-slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^article/([a-z0-9-]+)/?$ article.php?slug=$1 [L,QSA]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
