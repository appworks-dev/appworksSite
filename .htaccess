# Disable directory listing
Options -Indexes

# Custom 404 page
ErrorDocument 404 /404.html

# Enable URL rewriting
RewriteEngine On
RewriteBase /

# Auto-serve WebP images when browser supports it
RewriteCond %{HTTP_ACCEPT} image/webp
RewriteCond %{REQUEST_URI} (.+)\.(png|jpg|jpeg)$
RewriteCond %{DOCUMENT_ROOT}%1.webp -f
RewriteRule (.+)\.(png|jpg|jpeg)$ $1.webp [T=image/webp,L]

<IfModule mod_headers.c>
  <FilesMatch "\.(png|jpg|jpeg)$">
    Header append Vary Accept
  </FilesMatch>
</IfModule>

# Set default homepage
DirectoryIndex home.html index.html index.php

# --- Scheme & host normalization (first, to avoid redirect chains) ---

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Remove trailing slash from URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# --- Canonical URL redirects ---

# Redirect /home.html to / (home.html is DirectoryIndex, canonical is /)
RewriteRule ^home\.html$ / [R=301,L]

# Redirect /index.html to root
RewriteRule ^index\.html$ / [R=301,L]

# Redirect old /article?id=XX to article.php for 301 processing
RewriteCond %{QUERY_STRING} id= [NC]
RewriteRule ^article/?$ article.php [L,QSA]

# Redirect old /article?slug=XX to clean /article/slug URL
RewriteCond %{QUERY_STRING} slug=([a-z0-9-]+)
RewriteRule ^article/?$ https://app-works.app/article/%1? [R=301,L]

# Redirect direct article.php?slug= access to clean /article/slug URL
RewriteCond %{THE_REQUEST} article\.php
RewriteCond %{QUERY_STRING} slug=([a-z0-9-]+)
RewriteRule ^article\.php$ https://app-works.app/article/%1? [R=301,L]

# Redirect extensionless page URLs to .html (fixes 404s from old links)
# Redirect /articles to /insights directly (avoid double redirect through articles.html)
RewriteRule ^articles$ /insights [R=301,L]

RewriteRule ^(about|partners|projects|media|sport|cms|consultation)$ https://app-works.app/$1.html [R=301,L]

# Redirect broken slug (diacritics stripped incorrectly)
RewriteRule ^article/da-li-mikro-uenje-moe-da-motivie-decu-da-ue$ /article/da-li-mikro-ucenje-moze-da-motivise-decu-da-uce [R=301,L]

# Redirect old /oneArticle/ID/slug pattern to clean /article/slug
RewriteRule ^oneArticle/[0-9]+/(.+)$ /article/$1 [R=301,L]

# Redirect old /page/contact to /about.html
RewriteRule ^page/contact$ /about.html [R=301,L]

# Redirect /appworksSite/article/slug to /article/slug (bad external link)
RewriteRule ^appworksSite/article/(.+)$ /article/$1 [R=301,L]

# Redirect broken /article//span[ and other garbage article URLs to articles listing
RewriteRule ^article//.*$ /insights [R=301,L]

# Redirect /image/cache/ paths to homepage (old mPanel CMS paths)
RewriteRule ^image/cache/.*$ / [R=301,L]

# Redirect /images/country-flag-16X16/ to homepage (real dir, 403)
RedirectMatch 301 ^/images/country-flag-.* /

# --- Insights page redirects ---

# Redirect old /articles.html to /insights
RewriteRule ^articles\.html$ /insights [R=301,L]

# --- Internal rewrites (no redirect, serve content) ---

# Serve dynamic sitemap and insights page via PHP
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^insights/?$ articles.php [L]

# Rewrite clean article URLs to article.php with slug parameter
# Example: /article/my-article-slug -> /article.php?slug=my-article-slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^article/([a-z0-9-]+)/?$ article.php?slug=$1 [L,QSA]
